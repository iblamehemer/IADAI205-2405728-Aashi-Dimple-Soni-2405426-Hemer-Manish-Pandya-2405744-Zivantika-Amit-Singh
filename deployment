# BrandSphere AI — Streamlit Cloud Deployment Config
name: brandsphere-ai
entrypoint: app.py
python: "3.11"
dependencies:
  - requirements.txt
[theme]
primaryColor = "#F4A261"
backgroundColor = "#0E1117"
secondaryBackgroundColor = "#1B2838"
